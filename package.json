    "test:symbols": "node tests/symbol-database.test.mjs",
    "test:symbol-audit": "node tests/symbol-database-audit.mjs",
    "test:symbol-editor": "node tests/symbol-editor-contract.test.mjs",
    "test:symbol-learning": "node tests/symbol-learning-contract.test.mjs",
    "test:themes": "node tests/theme-contrast-contract.test.mjs",
    "test:flow-mode": "node tests/flow-mode-reader-contract.test.mjs",
    "test:project-setup-calculations": "node tests/project-setup-calculation-contract.test.mjs",
    "test:voice": "node tests/voice-command-contract.test.mjs",
    "test:navigation": "node tests/navigation-contract.test.mjs",
    "test:typography": "node tests/typography-contract.test.mjs",
    "test:settings": "node tests/settings-contract.test.mjs",
    "test:cloud-sync": "node tests/cloud-sync-contract.test.mjs",
